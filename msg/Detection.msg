# Detection - Representa una detección de producto
int32 class_id          # ID de la clase detectada
string class_name       # Nombre de la clase detectada
float32 confidence      # Confianza de la detección (0.0 a 1.0)
int32 bbox_x1           # Coordenada x del bbox superior izquierdo
int32 bbox_y1           # Coordenada y del bbox superior izquierdo
int32 bbox_x2           # Coordenada x del bbox inferior derecho
int32 bbox_y2           # Coordenada y del bbox inferior derecho

